<Window x:Class="CyberSecurityApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SecureShield Hub" Height="650" Width="850" WindowStartupLocation="CenterScreen" Background="#F4F6F9">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="4" Padding="15" Margin="10">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="SECURESHIELD HUB" Foreground="White" FontWeight="Bold" FontSize="22"/>
                <TextBlock Text="Cybersecurity Risk Management Dashboard" Foreground="#BDC3C7" FontSize="12" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Security Chatbot">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0">
                        <TextBox Name="ChatHistoryBox" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" Background="#F8F9FA" Padding="10"/>
                    </ScrollViewer>
                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="ChatInputBox" Grid.Column="0" Height="35" VerticalContentAlignment="Center" KeyDown="ChatInputBox_KeyDown"/>
                        <Button Name="SendButton" Grid.Column="1" Content="Send" Margin="8,0,0,0" Background="#3498DB" Foreground="White" Click="SendButton_Click"/>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Task Manager">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#BDC3C7" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Task Name:" FontWeight="Bold"/>
                                <TextBox x:Name="TaskNameInput" Height="30"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Category:" FontWeight="Bold"/>
                                <ComboBox x:Name="CategoryComboBox" Height="30">
                                    <ComboBoxItem Content="Network Security"/>
                                    <ComboBoxItem Content="Access Management"/>
                                    <ComboBoxItem Content="System Maintenance"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,15,0">
                                <TextBlock Text="Priority:" FontWeight="Bold"/>
                                <ComboBox x:Name="PriorityComboBox" Height="30">
                                    <ComboBoxItem Content="Low"/>
                                    <ComboBoxItem Content="High"/>
                                    <ComboBoxItem Content="Critical"/>
                                </ComboBox>
                            </StackPanel>
                            <Button x:Name="AddTaskButton" Grid.Column="3" Content="Commit" Width="100" Background="#2ECC71" Foreground="White" Click="AddTaskButton_Click"/>
                        </Grid>
                    </Border>
                    <DataGrid x:Name="TasksDataGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
                </Grid>
            </TabItem>
            <TabItem Header="Knowledge Quiz">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#34495E" Padding="10">
                        <Grid>
                            <TextBlock x:Name="QuizProgressText" Foreground="White"/>
                            <TextBlock x:Name="QuizScoreText" Foreground="#2ECC71" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="QuestionTextBlock" Grid.Row="1" FontSize="16" FontWeight="Bold" Margin="0,15"/>
                    <StackPanel Grid.Row="2">
                        <RadioButton x:Name="OptionARadio" GroupName="Quiz" Margin="0,5"/>
                        <RadioButton x:Name="OptionBRadio" GroupName="Quiz" Margin="0,5"/>
                        <RadioButton x:Name="OptionCRadio" GroupName="Quiz" Margin="0,5"/>
                        <RadioButton x:Name="OptionDRadio" GroupName="Quiz" Margin="0,5"/>
                    </StackPanel>
                    <Button x:Name="SubmitAnswerButton" Grid.Row="3" Content="Submit Answer" Background="#3498DB" Foreground="White" Click="SubmitAnswerButton_Click"/>
                </Grid>
            </TabItem>
            <TabItem Header="Activity Auditor">
                <Grid Margin="15">
                    <ListBox x:Name="AuditLogListBox" FontFamily="Consolas" FontSize="12" Background="#F8F9FA"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>