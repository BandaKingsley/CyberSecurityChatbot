<Window x:Class="CyberSecurityApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Risk Management Dashboard"
        Height="650" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="4" Padding="15" Margin="10">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="SECURESHIELD HUB - PORTFOLIO OF EVIDENCE"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="18"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Cybersecurity Risk Management Dashboard"
                           Foreground="White"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Security Chatbot">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <TextBox Name="ChatHistoryBox"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Background="#F8F9FA"
                                 Padding="10"/>
                    </ScrollViewer>

                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="ChatInputBox"
                                 Grid.Column="0"
                                 Height="35"
                                 VerticalContentAlignment="Center"
                                 Padding="5"
                                 KeyDown="ChatInputBox_KeyDown"/>
                        <Button Name="SendButton"
                                Grid.Column="1"
                                Content="Send"
                                Height="35"
                                Margin="8,0,0,0"
                                Background="#3498DB"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="SendButton_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Task Manager">
                <Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Knowledge Quiz">
                <Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Activity Auditor">
                <Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>