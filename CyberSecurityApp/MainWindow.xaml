<Window x:Class="CyberSecurityApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Risk Management Dashboard"
        Height="650" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="4" Padding="15" Margin="10">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="SECURESHIELD HUB - PORTFOLIO OF EVIDENCE"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="18"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Cybersecurity Risk Management Dashboard"
                           Foreground="White"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Security Chatbot">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <TextBox Name="ChatHistoryBox"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Background="#F8F9FA"
                                 Padding="10"/>
                    </ScrollViewer>

                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="ChatInputBox"
                                 Grid.Column="0"
                                 Height="35"
                                 VerticalContentAlignment="Center"
                                 Padding="5"
                                 KeyDown="ChatInputBox_KeyDown"/>
                        <Button Name="SendButton"
                                Grid.Column="1"
                                Content="Send"
                                Height="35"
                                Margin="8,0,0,0"
                                Background="#3498DB"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="SendButton_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Task Manager">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Security Task Action Item:" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="TaskNameInput" Height="30" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Category Domain:" FontWeight="Bold" Margin="0,0,0,5"/>
                                <ComboBox x:Name="CategoryComboBox" Height="30" SelectedIndex="0">
                                    <ComboBoxItem Content="Network Security"/>
                                    <ComboBoxItem Content="Access Management"/>
                                    <ComboBoxItem Content="System Maintenance"/>
                                    <ComboBoxItem Content="Awareness Training"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,15,0">
                                <TextBlock Text="Priority:" FontWeight="Bold" Margin="0,0,0,5"/>
                                <ComboBox x:Name="PriorityComboBox" Height="30" SelectedIndex="0">
                                    <ComboBoxItem Content="Low"/>
                                    <ComboBoxItem Content="Medium"/>
                                    <ComboBoxItem Content="High"/>
                                    <ComboBoxItem Content="Critical"/>
                                </ComboBox>
                            </StackPanel>

                            <Button x:Name="AddTaskButton" Grid.Column="3" Content="Commit Task" Width="120" Height="30" VerticalAlignment="Bottom"
                                    Background="#2ECC71" Foreground="White" FontWeight="Bold" Click="AddTaskButton_Click"/>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="TasksDataGrid" Grid.Row="1" AutoGenerateColumns="True" 
                              Background="White" BorderBrush="#BDC3C7" AlternatingRowBackground="#F9FAFB" 
                              IsReadOnly="True" RowHeaderWidth="0"/>
                </Grid>
            </TabItem>

            <TabItem Header="Knowledge Quiz">
                <Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Activity Auditor">
                <Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>